GROQ_API_KEY=your_groq_api_key_here
ENCRYPTION_KEY=your_base64_encryption_key_here
SELLER_PASSWORD=your_secure_developer_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ── Alert & Monitoring Settings ─────────────────────────────────────────
# Email address that receives alert notifications (leave blank to disable)
ALERT_EMAIL=your_alert_recipient@gmail.com
# Requests per minute threshold — triggers traffic spike alert
ALERT_TRAFFIC_RPM=50
# Error rate % threshold — triggers error rate alert (requires ≥3 req/min)
ALERT_ERROR_RATE_PCT=20
# Estimated tokens per minute threshold — triggers token usage alert
ALERT_TOKENS_PER_MIN=50000
# Minimum minutes between repeat alerts of the same type (prevents spam)
ALERT_COOLDOWN_MINUTES=15
